NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
GITHUB_TOKEN=your_github_personal_access_token

# Personal access token for the Supabase Management API. Used by the
# project-local Supabase MCP server (see .mcp.json) so Claude Code can
# run migrations and execute SQL in this project without copy-paste.
# Create one at: https://supabase.com/dashboard/account/tokens
# Claude Code reads this from the shell env, not .env.local — export it
# from ~/.bashrc / ~/.zshrc, or run `set -a; source .env.local; set +a`
# before launching `claude`.
SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token_here
